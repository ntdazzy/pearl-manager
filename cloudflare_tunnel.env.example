# PEARL MINER MANAGER - CLOUDFLARE TUNNEL
#
# 1. Cloudflare Zero Trust -> Networks -> Tunnels -> Create tunnel.
# 2. Choose "Cloudflared", pick Linux, copy the tunnel token.
# 3. Copy this file to cloudflare_tunnel.env and paste the token below.
#
# This file may contain secrets. Do not commit cloudflare_tunnel.env.

CLOUDFLARE_TUNNEL_TOKEN=

# Local dashboard target. Keep this local; cloudflared will expose it.
CLOUDFLARE_TUNNEL_TARGET=http://127.0.0.1:8555

# Optional local service name.
CLOUDFLARE_TUNNEL_SERVICE=pearl-cloudflared.service

